<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_lg"
    app:cardCornerRadius="@dimen/dialog_corner_radius"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Confirmation Icon -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardCornerRadius="5dp"
            app:cardBackgroundColor="#FFF3E0"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/warning" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Confirmation Title -->
        <TextView
            android:id="@+id/tv_confirmation_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Confirm Action"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <!-- Confirmation Message -->
        <TextView
            android:id="@+id/tv_confirmation_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Are you sure you want to proceed?"
            android:textSize="@dimen/text_size_body_large"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:spacing="@dimen/spacing_sm">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirmation_cancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_small"
                android:layout_weight="1"
                android:text="Cancel"
                android:textSize="@dimen/text_size_body_large"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:cornerRadius="@dimen/corner_md"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirmation_action"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_small"
                android:layout_weight="1"
                android:text="Confirm"
                android:textSize="@dimen/text_size_body_large"
                android:textStyle="bold"
                app:cornerRadius="@dimen/corner_md"
                app:backgroundTint="@color/primary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

