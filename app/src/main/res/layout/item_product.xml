<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/corner_md"
    app:cardElevation="1dp"
    app:strokeColor="@color/stroke_default"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md">

            <!-- Product Image -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="54dp"
                android:layout_height="54dp"
                app:cardBackgroundColor="#E4F1AC"
                app:cardCornerRadius="@dimen/corner_sm"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/iv_product"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_product_placeholder"/>
                <!-- ↑ NO tint here — tint was overriding your bitmap -->

            </com.google.android.material.card.MaterialCardView>

            <!-- Product Details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product Name"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body_large"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="Category"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_caption"/>

                <TextView
                    android:id="@+id/tv_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="₱0.00"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_size_body_large"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/layout_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- Delete Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_delete"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFCDD2"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="#D32F2F"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Add Stock Button (+) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_add_stock"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#E4F1AC"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_input_add"
                        app:tint="#3a6e0f"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <!-- Stock Badge - Top Right Corner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            app:cardBackgroundColor="@color/stock_badge_bg"
            app:cardCornerRadius="@dimen/corner_sm"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tv_stock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="In Stock: 0"
                android:textColor="@color/stock_text_green"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold"/>
        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>
</com.google.android.material.card.MaterialCardView>