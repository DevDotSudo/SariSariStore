<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_lg"
    app:cardCornerRadius="@dimen/dialog_corner_radius"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/spacing_lg">

        <!-- Error Badge -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardCornerRadius="5dp"
            app:cardBackgroundColor="#FFEBEE"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_dialog_alert"
                app:tint="@color/error" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Error Title -->
        <TextView
            android:id="@+id/tv_error_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Error"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <!-- Error Message -->
        <TextView
            android:id="@+id/tv_error_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="An error occurred. Please try again."
            android:textSize="@dimen/text_size_body_large"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_error_action"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_medium"
            android:text="Dismiss"
            android:textSize="@dimen/text_size_body_large"
            android:textStyle="bold"
            app:cornerRadius="@dimen/corner_md"
            app:backgroundTint="@color/error" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

